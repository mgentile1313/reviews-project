# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and is read by both the Next.js app and the Python scripts.

# --- Supabase (Postgres + pgvector) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser. Used by API routes and Python scripts.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic Claude (brief generation / reasoning) ---
ANTHROPIC_API_KEY=

# --- OpenAI (text-embedding-3-small) ---
OPENAI_API_KEY=

# --- Bright Data Web Scraper API (data ingestion) ---
BRIGHTDATA_API_KEY=
